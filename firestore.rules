rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read site content, but only authenticated users (admins) can write
    match /siteContent/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default rule to prevent unauthorized access to other collections
    // Update as more collections are added
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
